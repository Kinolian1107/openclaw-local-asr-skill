# ASR Configuration
# Copy this file to .env and adjust as needed

# speaches API endpoint
SPEACHES_URL=http://localhost:18996

# Whisper model to use
ASR_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2

# Working directory for audio files
ASR_DIR=/home/kino/asr

# HuggingFace model cache directory
HF_HOME=/home/kino/ollama-models/huggingface-hub

# HuggingFace token (required for speaker diarization)
HF_TOKEN=hf_your_token_here
